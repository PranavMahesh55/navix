NODE_ENV=development
PORT=8080

FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080/api
VITE_DEFAULT_PROMPT=Explain query schema graph loading.
VITE_DEFAULT_REPO_URL=https://gitlab.com/gitlab-community/gitlab-org/orbit/knowledge-graph

GITLAB_BASE_URL=https://gitlab.com
